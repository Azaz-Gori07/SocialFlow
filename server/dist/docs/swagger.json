{
    "openapi": "3.0.0",
    "info": {
        "title": "SocialFlow AI - Phase 1 API Specs",
        "version": "1.0.0",
        "description": "Production-grade endpoints for Authentication, Workspace collaboration, and RBAC members administration."
    },
    "servers": [
        {
            "url": "http://localhost:5000/api",
            "description": "Local Development Server"
        }
    ],
    "paths": {
        "/auth/register": {
            "post": {
                "summary": "Register a new user profile",
                "description": "Creates a new user, hashes the password, and provisions a default personal workspace for them.",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": ["email", "password", "fullName"],
                                "properties": {
                                    "email": { "type": "string", "format": "email" },
                                    "password": { "type": "string", "minLength": 8 },
                                    "fullName": { "type": "string", "minLength": 2 }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "201": { "description": "User created successfully" },
                    "400": { "description": "Validation failed / bad request parameters" },
                    "409": { "description": "Email address already registered" }
                }
            }
        },
        "/auth/login": {
            "post": {
                "summary": "Log in and obtain access keys",
                "description": "Authenticates credentials and signs access + refresh tokens.",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": ["email", "password"],
                                "properties": {
                                    "email": { "type": "string", "format": "email" },
                                    "password": { "type": "string" }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": { "description": "Login successful" },
                    "401": { "description": "Invalid email or password" }
                }
            }
        },
        "/auth/refresh": {
            "post": {
                "summary": "Refresh session tokens",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": ["refreshToken"],
                                "properties": {
                                    "refreshToken": { "type": "string" }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": { "description": "Token refreshed successfully" },
                    "401": { "description": "Session token invalid or expired" }
                }
            }
        },
        "/auth/me": {
            "get": {
                "summary": "Retrieve currently authenticated user profile",
                "security": [{ "BearerAuth": [] }],
                "responses": {
                    "200": { "description": "Profile details returned" },
                    "401": { "description": "Access token unauthorized" }
                }
            }
        },
        "/workspace": {
            "post": {
                "summary": "Create a new organizational workspace",
                "security": [{ "BearerAuth": [] }],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": ["name"],
                                "properties": {
                                    "name": { "type": "string", "minLength": 2, "maxLength": 50 }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "201": { "description": "Workspace created successfully" },
                    "401": { "description": "Unauthorized" }
                }
            }
        },
        "/workspace/list": {
            "get": {
                "summary": "List all workspaces the user has access to",
                "security": [{ "BearerAuth": [] }],
                "responses": {
                    "200": { "description": "List returned successfully" }
                }
            }
        },
        "/workspace/invite": {
            "post": {
                "summary": "Invite a team member to a workspace",
                "security": [{ "BearerAuth": [] }],
                "description": "Requires Owner or Admin workspace role.",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": ["workspaceId", "email", "role"],
                                "properties": {
                                    "workspaceId": { "type": "string" },
                                    "email": { "type": "string", "format": "email" },
                                    "role": { "type": "string", "enum": ["admin", "editor", "viewer"] }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "201": { "description": "Invitation completed successfully" },
                    "403": { "description": "Insufficient permissions (caller must be owner/admin)" },
                    "404": { "description": "Workspace or target user not found" }
                }
            }
        },
        "/workspace/{workspaceId}/members": {
            "get": {
                "summary": "Get member roster for a workspace",
                "security": [{ "BearerAuth": [] }],
                "parameters": [
                    {
                        "name": "workspaceId",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "string" }
                    }
                ],
                "responses": {
                    "200": { "description": " Roster list returned" },
                    "403": { "description": "Access denied" }
                }
            }
        },
        "/workspace/{workspaceId}/member": {
            "delete": {
                "summary": "Remove a member from a workspace",
                "security": [{ "BearerAuth": [] }],
                "description": "Requires Admin role (cannot remove owners/admins) or Owner role.",
                "parameters": [
                    {
                        "name": "workspaceId",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "string" }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": ["userId"],
                                "properties": {
                                    "userId": { "type": "string" }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": { "description": "Member removed successfully" },
                    "403": { "description": "Insufficient hierarchy permissions" }
                }
            }
        },
        "/social/connect/{platform}": {
            "get": {
                "summary": "Get social platform authorization URL",
                "description": "Generates and returns the OAuth 2.0 authorization URL for a social platform (twitter, linkedin, youtube).",
                "security": [{ "BearerAuth": [] }],
                "parameters": [
                    {
                        "name": "platform",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "enum": ["twitter", "linkedin", "youtube"]
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Authorization URL successfully generated",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "success": { "type": "boolean" },
                                        "message": { "type": "string" },
                                        "data": {
                                            "type": "object",
                                            "properties": {
                                                "url": { "type": "string" }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "401": { "description": "Unauthorized access" }
                }
            }
        },
        "/social/callback/{platform}": {
            "get": {
                "summary": "Receive OAuth redirect callback",
                "description": "Exchanges code for access/refresh tokens, encrypts tokens, registers social account, and redirects user to frontend dashboard.",
                "parameters": [
                    {
                        "name": "platform",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "enum": ["twitter", "linkedin", "youtube"]
                        }
                    },
                    {
                        "name": "code",
                        "in": "query",
                        "required": true,
                        "schema": { "type": "string" }
                    },
                    {
                        "name": "state",
                        "in": "query",
                        "required": true,
                        "schema": { "type": "string" }
                    }
                ],
                "responses": {
                    "302": { "description": "Successful connection redirects browser to React settings dashboard" }
                }
            }
        },
        "/social/accounts": {
            "get": {
                "summary": "Retrieve list of connected social accounts",
                "description": "Lists all connected social accounts for the user (access/refresh tokens are stripped for client safety).",
                "security": [{ "BearerAuth": [] }],
                "responses": {
                    "200": { "description": "Accounts list returned successfully" },
                    "401": { "description": "Unauthorized access" }
                }
            }
        },
        "/social/accounts/{id}": {
            "delete": {
                "summary": "Disconnect a social account connection",
                "description": "Deletes the social account connection and cascades deletions of associated comments and analytics.",
                "security": [{ "BearerAuth": [] }],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "string" }
                    }
                ],
                "responses": {
                    "200": { "description": "Social account disconnected successfully" },
                    "401": { "description": "Unauthorized access" },
                    "404": { "description": "Social account not found" }
                }
            }
        },
        "/posts": {
            "post": {
                "summary": "Create a new post (draft or scheduled)",
                "security": [{ "BearerAuth": [] }],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": ["content", "platforms"],
                                "properties": {
                                    "content": { "type": "string" },
                                    "platforms": {
                                        "type": "array",
                                        "items": { "type": "string", "enum": ["twitter", "instagram", "facebook", "linkedin", "youtube", "tiktok"] }
                                    },
                                    "status": { "type": "string", "enum": ["draft", "scheduled"], "default": "draft" },
                                    "scheduledAt": { "type": "string", "format": "date-time" },
                                    "media": { "type": "array", "items": { "type": "string" } },
                                    "platformContent": { "type": "object" }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "201": { "description": "Post successfully created" },
                    "400": { "description": "Validation failed / schedule constraints violated" },
                    "401": { "description": "Unauthorized" }
                }
            }
        },
        "/posts/list": {
            "get": {
                "summary": "Retrieve user posts",
                "security": [{ "BearerAuth": [] }],
                "responses": {
                    "200": { "description": "List returned successfully" },
                    "401": { "description": "Unauthorized" }
                }
            }
        },
        "/posts/{id}": {
            "get": {
                "summary": "Retrieve details of a single post",
                "security": [{ "BearerAuth": [] }],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "string" }
                    }
                ],
                "responses": {
                    "200": { "description": "Post details returned" },
                    "401": { "description": "Unauthorized" },
                    "404": { "description": "Post not found" }
                }
            },
            "put": {
                "summary": "Update post content or schedule",
                "security": [{ "BearerAuth": [] }],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "string" }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "content": { "type": "string" },
                                    "platforms": {
                                        "type": "array",
                                        "items": { "type": "string", "enum": ["twitter", "instagram", "facebook", "linkedin", "youtube", "tiktok"] }
                                    },
                                    "status": { "type": "string", "enum": ["draft", "scheduled"] },
                                    "scheduledAt": { "type": "string", "format": "date-time" },
                                    "media": { "type": "array", "items": { "type": "string" } },
                                    "platformContent": { "type": "object" }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": { "description": "Post successfully updated" },
                    "400": { "description": "Validation failed / published posts cannot be edited" },
                    "401": { "description": "Unauthorized" },
                    "404": { "description": "Post not found" }
                }
            },
            "delete": {
                "summary": "Cancel schedule and delete post",
                "security": [{ "BearerAuth": [] }],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "string" }
                    }
                ]
            }
        },
        "/comments": {
            "get": {
                "summary": "Retrieve comments for connected accounts in the workspace",
                "security": [{ "BearerAuth": [] }],
                "parameters": [
                    {
                        "name": "workspaceId",
                        "in": "query",
                        "required": true,
                        "schema": { "type": "string" }
                    },
                    {
                        "name": "platform",
                        "in": "query",
                        "schema": { "type": "string", "enum": ["twitter", "instagram", "facebook", "linkedin", "youtube", "tiktok"] }
                    },
                    {
                        "name": "status",
                        "in": "query",
                        "schema": { "type": "string", "enum": ["unresolved", "resolved"] }
                    },
                    {
                        "name": "assignedTo",
                        "in": "query",
                        "schema": { "type": "string" }
                    }
                ],
                "responses": {
                    "200": { "description": "Comments list retrieved" },
                    "401": { "description": "Unauthorized" },
                    "403": { "description": "Forbidden workspace access" }
                }
            }
        },
        "/comments/reply": {
            "post": {
                "summary": "Submit a reply to a comment",
                "security": [{ "BearerAuth": [] }],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": ["workspaceId", "commentId", "message"],
                                "properties": {
                                    "workspaceId": { "type": "string" },
                                    "commentId": { "type": "string" },
                                    "message": { "type": "string" }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": { "description": "Reply added and comment auto-resolved" },
                    "400": { "description": "Validation error" },
                    "401": { "description": "Unauthorized" },
                    "403": { "description": "Forbidden workspace access" },
                    "404": { "description": "Comment not found" }
                }
            }
        },
        "/comments/resolve/{id}": {
            "put": {
                "summary": "Mark comment status resolved / unresolved",
                "security": [{ "BearerAuth": [] }],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "string" }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": ["workspaceId", "status"],
                                "properties": {
                                    "workspaceId": { "type": "string" },
                                    "status": { "type": "string", "enum": ["unresolved", "resolved"] }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": { "description": "Status updated successfully" },
                    "400": { "description": "Validation error" },
                    "401": { "description": "Unauthorized" },
                    "403": { "description": "Forbidden workspace access" },
                    "404": { "description": "Comment not found" }
                }
            }
        },
        "/comments/assign/{id}": {
            "put": {
                "summary": "Assign comment to teammate",
                "security": [{ "BearerAuth": [] }],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "string" }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": ["workspaceId", "assignedTo"],
                                "properties": {
                                    "workspaceId": { "type": "string" },
                                    "assignedTo": { "type": "string" }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": { "description": "Comment assigned successfully" },
                    "400": { "description": "Validation error / User not workspace member" },
                    "401": { "description": "Unauthorized" },
                    "403": { "description": "Forbidden workspace access" },
                    "404": { "description": "Comment not found" }
                }
            }
        },
        "/comments/ai-suggestions": {
            "post": {
                "summary": "Request AI reply suggestions",
                "security": [{ "BearerAuth": [] }],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": ["workspaceId", "commentId"],
                                "properties": {
                                    "workspaceId": { "type": "string" },
                                    "commentId": { "type": "string" }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": { "description": "AI suggestions generated successfully" },
                    "400": { "description": "Validation error" },
                    "401": { "description": "Unauthorized" },
                    "403": { "description": "Forbidden workspace access" },
                    "404": { "description": "Comment not found" }
                }
            }
        }
    },
    "components": {
        "securitySchemes": {
            "BearerAuth": {
                "type": "http",
                "scheme": "bearer",
                "bearerFormat": "JWT"
            }
        }
    }
}
