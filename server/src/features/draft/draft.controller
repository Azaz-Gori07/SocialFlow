import { Response, NextFunction } from 'express';
import { DraftService } from './draft.service';
import { ApiResponse } from '../../shared/utils/response.util';
import { AuthenticatedRequest } from '../../shared/middleware/rbac.middleware';
import { AppError } from '../../shared/errors/appError';

export class DraftController {
  constructor(private draftService: DraftService) {}

  create = async (req: AuthenticatedRequest, res: Response, next: NextFunction) => {
    try {
      if (!req.user) return next(AppError.unauthorized());
      const draft = await this.draftService.createDraft(req.body, req.user.id);
      return ApiResponse.success(res, draft, 'Draft created successfully', 201);
    } catch (error) { next(error); }
  };

  uploadMedia = async (req: AuthenticatedRequest, res: Response, next: NextFunction) => {
    try {
      if (!req.user) return next(AppError.unauthorized());
      const { id } = req.params;
      const draft = await this.draftService.uploadMedia(id, req.body, req.user.id);
      return ApiResponse.success(res, draft, 'Media uploaded successfully');
    } catch (error) { next(error); }
  };

  list = async (req: AuthenticatedRequest, res: Response, next: NextFunction) => {
    try {
      if (!req.user) return next(AppError.unauthorized());
      const limit = Math.max(1, Math.min(parseInt(req.query.limit as string, 10) || 50, 200));
      const offset = Math.max(0, parseInt(req.query.offset as string, 10) || 0);
      const platform = req.query.platform as string | undefined;
      const status = req.query.status as string | undefined;
      const result = await this.draftService.listDrafts(req.user.id, { limit, offset, platform, status });
      return ApiResponse.success(res, result, 'Drafts retrieved successfully');
    } catch (error) { next(error); }
  };

  get = async (req: AuthenticatedRequest, res: Response, next: NextFunction) => {
    try {
      if (!req.user) return next(AppError.unauthorized());
      const { id } = req.params;
      const draft = await this.draftService.getDraft(id, req.user.id);
      return ApiResponse.success(res, draft, 'Draft retrieved successfully');
    } catch (error) { next(error); }
  };

  update = async (req: AuthenticatedRequest, res: Response, next: NextFunction) => {
    try {
      if (!req.user) return next(AppError.unauthorized());
      const { id } = req.params;
      const draft = await this.draftService.editDraft(id, req.body, req.user.id);
      return ApiResponse.success(res, draft, 'Draft updated successfully');
    } catch (error) { next(error); }
  };

  archive = async (req: AuthenticatedRequest, res: Response, next: NextFunction) => {
    try {
      if (!req.user) return next(AppError.unauthorized());
      const { id } = req.params;
      const draft = await this.draftService.archiveDraft(id, req.user.id);
      return ApiResponse.success(res, draft, 'Draft archived successfully');
    } catch (error) { next(error); }
  };

  delete = async (req: AuthenticatedRequest, res: Response, next: NextFunction) => {
    try {
      if (!req.user) return next(AppError.unauthorized());
      const { id } = req.params;
      await this.draftService.deleteDraft(id, req.user.id);
      return ApiResponse.success(res, null, 'Draft deleted successfully');
    } catch (error) { next(error); }
  };

  // Phase 2: Publishing
  queue = async (req: AuthenticatedRequest, res: Response, next: NextFunction) => {
    try {
      if (!req.user) return next(AppError.unauthorized());
      const { id } = req.params;
      const draft = await this.draftService.queueForPublishing(id, req.body, req.user.id);
      return ApiResponse.success(res, draft, 'Draft queued for publishing');
    } catch (error) { next(error); }
  };

  publish = async (req: AuthenticatedRequest, res: Response, next: NextFunction) => {
    try {
      if (!req.user) return next(AppError.unauthorized());
      const { id } = req.params;
      const draft = await this.draftService.publishNow(id, req.user.id);
      return ApiResponse.success(res, draft, 'Draft published');
    } catch (error) { next(error); }
  };

  retry = async (req: AuthenticatedRequest, res: Response, next: NextFunction) => {
    try {
      if (!req.user) return next(AppError.unauthorized());
      const { id } = req.params;
      const draft = await this.draftService.retryDraft(id, req.user.id);
      return ApiResponse.success(res, draft, 'Draft retry initiated');
    } catch (error) { next(error); }
  };

  // Phase 3: Publish History
  history = async (req: AuthenticatedRequest, res: Response, next: NextFunction) => {
    try {
      if (!req.user) return next(AppError.unauthorized());
      const { id } = req.params;
      const history = await this.draftService.getPublishHistory(id, req.user.id);
      return ApiResponse.success(res, history, 'Publish history retrieved');
    } catch (error) { next(error); }
  };
}

export default DraftController;